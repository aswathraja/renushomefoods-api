{
    "name": "renushomefoods-api",
    "private": true,
    "version": "1.0.0",
    "description": "API Services for the Renus Home Foods Website built with NestJS",
    "license": "MIT",
    "website": "https://renushomefoods.com",
    "author": "Aswath Raja",
    "email": "aswathraja@gamil.com",
    "scripts": {
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "sh -c 'mkdir -p .git/hooks && cp -r scripts/hooks/. .git/hooks/ && chmod +x .git/hooks/*' || true",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "rm -rf dist tsconfig.build.tsbuildinfo && nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "engines": {
        "npm": ">=10.0.0",
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.19",
        "@nestjs/core": "^11.1.19",
        "@nestjs/platform-express": "^11.1.19",
        "compression": "^1.8.1",
        "crypto-es": "^3.1.3",
        "dotenv": "^17.4.2",
        "exceljs": "^4.4.0",
        "handlebars": "^4.7.9",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "mysql2": "^3.22.0",
        "nodemailer": "^8.0.5",
        "puppeteer": "^24.40.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "sequelize": "^6.37.8",
        "sharp": "^0.34.5",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "lint-staged": "^16.4.0",
        "@secretlint/secretlint-rule-aws": "^11.7.1",
        "@secretlint/secretlint-rule-basicauth": "^11.7.1",
        "@secretlint/secretlint-rule-no-dotenv": "^11.7.1",
        "@secretlint/secretlint-rule-npm": "^11.7.1",
        "@secretlint/secretlint-rule-privatekey": "^11.7.1",
        "@secretlint/secretlint-rule-slack": "^11.7.1",
        "secretlint": "^11.7.1",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@nestjs/cli": "^11.0.19",
        "@nestjs/schematics": "^11.0.10",
        "@nestjs/testing": "^11.1.19",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.24",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "ajv": "^8.18.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "prettier": "^3.8.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2"
    }
}
